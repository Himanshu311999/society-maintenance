# Copy this file to .env and fill in your values.
# Do NOT commit your real credentials to source control.

# Backend server configuration
BACKEND_HOST=localhost
BACKEND_PORT=4000

# Frontend API endpoint (used by Vite client-side code when exposed via VITE_ prefix)
VITE_API_URL=http://localhost:4000/api

# PostgreSQL configuration
DATABASE_URL=postgresql://maintenance_user:StrongPassword123!@localhost:5432/maintenance_tracker
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=maintenance_tracker
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_SSL=false

# Optional runtime settings
NODE_ENV=development
